import { Button, CheckBox, VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export struct AgentInfo {
    id: string,
    name: string,
    model: string,
    status: string,            // "green" | "orange" | "red" | "gray"
    note: string,
    last-active: string,
    sessions-count: int,
    running-tasks: int,
}

export struct LogEntry {
    ts: string,
    level: string,             // "info" | "warn" | "error"
    message: string,
}

export component MainWindow inherits Window {
    title: "ClawAgentMonitor";
    preferred-width: 820px;
    preferred-height: 620px;
    background: #0f172a;

    // ------------ Properties exposées au Rust ------------
    in property <[AgentInfo]> agents;
    in property <string> gateway-status: "unknown";
    in property <string> gateway-runtime: "";
    in property <string> last-update: "-";
    in property <int> total-running-tasks: 0;
    in property <int> total-failures: 0;
    in property <bool> restart-in-progress: false;

    // Settings (Rust met à jour, et reçoit les *-toggled)
    in-out property <bool> auto-restart-enabled: false;
    in-out property <bool> auto-aggressive-enabled: false;
    in-out property <bool> start-at-login-enabled: false;
    in-out property <bool> notifications-enabled: true;

    // Journal du watchdog (lignes les plus récentes en haut)
    in property <[LogEntry]> watchdog-log;

    // ------------ Callbacks vers Rust ------------
    callback restart-gateway();
    callback auto-restart-toggled(bool);
    callback auto-aggressive-toggled(bool);
    callback start-at-login-toggled(bool);
    callback notifications-toggled(bool);

    VerticalBox {
        spacing: 8px;
        padding: 14px;

        // ====== Header (gateway + restart) ======
        HorizontalBox {
            spacing: 12px;

            Rectangle {
                background: gateway-status == "up" ? #064e3b
                          : gateway-status == "down" ? #7f1d1d
                          : #374151;
                border-radius: 6px;
                horizontal-stretch: 1;
                HorizontalBox {
                    padding: 10px;
                    spacing: 8px;
                    Rectangle {
                        width: 12px;
                        height: 12px;
                        border-radius: 6px;
                        y: (parent.height - self.height) / 2;
                        background: gateway-status == "up" ? #10b981
                                  : gateway-status == "down" ? #ef4444
                                  : #9ca3af;
                    }
                    VerticalBox {
                        spacing: 0;
                        Text {
                            text: "Gateway : " + gateway-status;
                            color: white;
                            font-size: 14px;
                            font-weight: 600;
                        }
                        Text {
                            text: gateway-runtime;
                            color: #cbd5e1;
                            font-size: 10px;
                        }
                    }
                }
            }

            Button {
                text: restart-in-progress ? "Redémarrage..." : "Relancer Gateway";
                enabled: !restart-in-progress && gateway-status != "up";
                clicked => { restart-gateway() }
            }
        }

        // ====== Stats globales ======
        Rectangle {
            background: #1e293b;
            border-radius: 4px;
            height: 28px;
            HorizontalBox {
                padding: 6px;
                Text {
                    text: total-running-tasks + " tâche" + (total-running-tasks > 1 ? "s" : "")
                          + " en cours · " + total-failures + " échec" + (total-failures > 1 ? "s" : "")
                          + " (cumul)";
                    color: #cbd5e1;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }

        // ====== Liste des agents (scrollable) ======
        ScrollView {
            min-height: 240px;
            vertical-stretch: 1;
            VerticalBox {
                spacing: 6px;
                for agent in agents: Rectangle {
                    background: #1f2937;
                    border-radius: 6px;
                    height: 64px;
                    HorizontalBox {
                        padding: 12px;
                        spacing: 12px;
                        alignment: stretch;

                        Rectangle {
                            width: 18px;
                            height: 18px;
                            border-radius: 9px;
                            y: (parent.height - self.height) / 2;
                            background: agent.status == "green" ? #10b981
                                      : agent.status == "orange" ? #f59e0b
                                      : agent.status == "red" ? #ef4444
                                      : #6b7280;
                        }

                        VerticalBox {
                            spacing: 2px;
                            horizontal-stretch: 1;
                            HorizontalBox {
                                spacing: 8px;
                                Text {
                                    text: agent.name;
                                    color: white;
                                    font-size: 14px;
                                    font-weight: 600;
                                }
                                Text {
                                    text: "(" + agent.id + ")";
                                    color: #94a3b8;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                            }
                            Text {
                                text: agent.note + " · " + agent.model;
                                color: #cbd5e1;
                                font-size: 11px;
                            }
                        }

                        VerticalBox {
                            horizontal-stretch: 0;
                            spacing: 2px;
                            Text {
                                text: agent.last-active;
                                color: #cbd5e1;
                                font-size: 11px;
                                horizontal-alignment: right;
                            }
                            Text {
                                text: agent.sessions-count + " sessions";
                                color: #64748b;
                                font-size: 10px;
                                horizontal-alignment: right;
                            }
                        }
                    }
                }
            }
        }

        // ====== Settings (checkboxes) ======
        Rectangle {
            background: #111827;
            border-radius: 6px;
            HorizontalBox {
                padding: 10px;
                spacing: 18px;
                CheckBox {
                    text: "Auto-restart watchdog";
                    checked: auto-restart-enabled;
                    toggled => {
                        auto-restart-enabled = self.checked;
                        if (!self.checked) { auto-aggressive-enabled = false; }
                        auto-restart-toggled(self.checked);
                    }
                }
                CheckBox {
                    text: "Auto-agressive (palier 3 sans confirmation)";
                    checked: auto-aggressive-enabled;
                    enabled: auto-restart-enabled;
                    toggled => {
                        auto-aggressive-enabled = self.checked;
                        auto-aggressive-toggled(self.checked);
                    }
                }
                CheckBox {
                    text: "Démarrer au login";
                    checked: start-at-login-enabled;
                    toggled => {
                        start-at-login-enabled = self.checked;
                        start-at-login-toggled(self.checked);
                    }
                }
                CheckBox {
                    text: "Notifications";
                    checked: notifications-enabled;
                    toggled => {
                        notifications-enabled = self.checked;
                        notifications-toggled(self.checked);
                    }
                }
            }
        }

        // ====== Journal watchdog ======
        Rectangle {
            background: #0b1220;
            border-radius: 6px;
            min-height: 110px;
            VerticalBox {
                padding: 8px;
                spacing: 4px;
                Text {
                    text: "Journal watchdog";
                    color: #94a3b8;
                    font-size: 10px;
                    font-weight: 600;
                }
                ScrollView {
                    min-height: 80px;
                    vertical-stretch: 1;
                    VerticalBox {
                        spacing: 1px;
                        for entry in watchdog-log: HorizontalBox {
                            spacing: 6px;
                            Text {
                                text: entry.ts;
                                color: #64748b;
                                font-size: 10px;
                                width: 64px;
                            }
                            Text {
                                text: "[" + entry.level + "]";
                                color: entry.level == "error" ? #ef4444
                                     : entry.level == "warn" ? #f59e0b
                                     : #38bdf8;
                                font-size: 10px;
                                width: 48px;
                            }
                            Text {
                                text: entry.message;
                                color: #cbd5e1;
                                font-size: 10px;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }
            }
        }

        // ====== Footer ======
        Rectangle {
            height: 22px;
            HorizontalBox {
                padding-left: 8px;
                padding-right: 8px;
                Text {
                    text: "ClawAgentMonitor v0.1.0";
                    color: #64748b;
                    font-size: 10px;
                    vertical-alignment: center;
                }
                Text {
                    text: "Dernière MAJ : " + last-update;
                    color: #64748b;
                    font-size: 10px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }
    }
}
